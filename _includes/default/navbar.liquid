<header class="site-header">
    {% assign current_page = page %}
    {% if current_page.lang == 'en' %}
        {% assign home_href = '/index_en.html' %}
    {% else %}
        {% assign home_href = '/' %}
    {% endif %}

    <!-- Logo and title -->
	<div class="branding">
        {% if site.avatar %}
		<a href="{{ home_href | relative_url }}">
			<img alt="logo img" class="avatar" src="{{ site.avatar | relative_url }}" loading="lazy"/>
		</a>
        {% endif %}
        <a class="site-title" aria-label="{{ site.title }}" href="{{ home_href | relative_url }}">
        {% if current_page.lang == 'en' %}{{ site.title }}{% else %}Hem{% endif %}
		</a>
	</div>

    <!-- Menu -->
    <nav class="clear">
        <!-- Toggle menu -->
        <a id="pull" aria-label="menu" class="toggle" href="#" role="button" onclick="event.preventDefault(); var m=document.querySelector('nav ul'); if(m) m.classList.toggle('hide'); return false;">
            <i class="fas fa-bars fa-lg"></i>
        </a>

        <!-- Menu items -->
        <ul class="hide">
            {% assign name_page = "" %}
            {% assign emptyArray = '' | split: '' %}
            {% assign menus = site.data.menu | default: emptyArray %}
            {% assign pages = site.pages | concat: menus | sort: 'position' %}
            {% assign nav_lang = current_page.lang | default: 'sv' %}
            {% for page in pages %}
                {% assign item_lang = page.lang | default: 'sv' %}
                {% assign nav_dup_key = page.title | append: '::' | append: item_lang %}
            {% unless page.title == null or page.hide or name_page contains nav_dup_key %}
                {% assign show_nav_item = false %}
                {% if item_lang == nav_lang %}
                    {% assign show_nav_item = true %}
                {% endif %}
                {% if show_nav_item %}
                <li class="separator"> | </li>
                <li>
                    <a class="clear" aria-label="{{ page.title }}" title="{{ page.title }}" href="{{ page.url | relative_url }}">
                        {% if page.icon %}
                            <i class="navbar-icon fas {{ page.icon }}" aria-hidden="true"></i>
                        {% endif %}
                        <span class="navbar-label">{{ page.title }}</span>
                    </a>
                </li>
                {% endif %}
            {% endunless %}
            {% assign name_page = nav_dup_key | append: '||' | append: name_page %}
            {% endfor %}

            {% if current_page.lang_alt %}
            <li class="separator"> | </li>
            <li>
                <a class="clear language-selector" aria-label="{% if current_page.lang == 'en' %}Swedish version{% else %}English version{% endif %}" title="{% if current_page.lang == 'en' %}Swedish version{% else %}English version{% endif %}" href="{{ current_page.lang_alt | relative_url }}">
                    <span class="navbar-lang-label">{% if current_page.lang == 'en' %}🇸🇪 På Svenska{% else %}🇬🇧 In English{% endif %}</span>
                </a>
            </li>
            {% endif %}

            {% if site.color_theme == 'auto' %}
            <li class="separator"> | </li>
            <li><a id="theme-toggle" title="Theme" aria-label="Theme" onclick="themeToggle()"></a></li>
            {% endif %}
        </ul>
    </nav>
</header>
